// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContentType {
  LANDING_PAGE
  RCS
  SMS
}

enum AuditAction {
  // Auth
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGED
  // Contents
  CONTENT_CREATED
  CONTENT_UPDATED
  CONTENT_DELETED
  CONTENT_PUBLISHED
  CONTENT_ARCHIVED
  // Design
  DESIGN_SAVED
  DESIGN_VERSION_CREATED
  DESIGN_VERSION_RESTORED
  DESIGN_VERSION_PURGED
  // Assets
  ASSET_UPLOADED
  ASSET_DELETED
  // Users
  USER_CREATED
  USER_UPDATED
  USER_DELETED
}

enum EntityType {
  USER
  CONTENT
  ASSET
}

// ==================== MODELS ====================

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   // bcrypt hashed
  firstName String?
  lastName  String?
  role      Role     @default(VIEWER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  contents      Content[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model AuditLog {
  id         Int         @id @default(autoincrement())
  userId     Int?
  action     AuditAction
  entityType EntityType
  entityId   Int?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==================== CONTENT SYSTEM ====================

model Content {
  id         Int           @id @default(autoincrement())
  type       ContentType
  ownerId    Int
  title      String
  status     ContentStatus @default(DRAFT)
  isFavorite Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  deletedAt  DateTime?     // Soft delete

  // Relations
  owner           User             @relation(fields: [ownerId], references: [id])
  landingPageData LandingPageData?
  rcsData         RCSData?
  smsData         SMSData?

  @@index([ownerId])
  @@index([type])
  @@index([status])
  @@index([isFavorite])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("contents")
}

model LandingPageData {
  id        Int      @id @default(autoincrement())
  contentId Int      @unique
  design    Json     // Full DesignDocument
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  content  Content                @relation(fields: [contentId], references: [id], onDelete: Cascade)
  versions ContentDesignVersion[]

  @@map("landing_page_data")
}

model ContentDesignVersion {
  id                Int      @id @default(autoincrement())
  landingPageDataId Int
  version           String   // "1.0", "1.1", etc.
  design            Json     // Full DesignDocument snapshot
  widgetCount       Int
  createdAt         DateTime @default(now())

  // Relations
  landingPageData LandingPageData @relation(fields: [landingPageDataId], references: [id], onDelete: Cascade)

  @@index([landingPageDataId])
  @@map("content_design_versions")
}

model RCSData {
  id        Int      @id @default(autoincrement())
  contentId Int      @unique
  message   Json?    // RCS message structure (null = not implemented yet)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("rcs_data")
}

model SMSData {
  id        Int      @id @default(autoincrement())
  contentId Int      @unique
  message   Json?    // SMS message structure (null = not implemented yet)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("sms_data")
}

// ==================== AI FEATURES ====================

model AIUsage {
  id              Int      @id @default(autoincrement())
  userId          Int
  periodKey       String   // YYYY-MM format for monthly tracking
  count           Int      @default(0)
  lastGeneratedAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, periodKey])
  @@index([userId])
  @@index([periodKey])
  @@map("ai_usage")
}
