#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────
# init-env — Initialise les .env depuis les .env.example
#            et injecte les secrets partagés depuis
#            <monorepo-root>/.config/secrets
# ─────────────────────────────────────────────────────────────
# Usage:  ./bin/init-env          (depuis v2/platform/)
#         ./bin/init-env --force  (écrase les .env existants)
# ─────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLATFORM_DIR="$(dirname "$SCRIPT_DIR")"
MONOREPO_ROOT="$(cd "$PLATFORM_DIR/../.." && pwd)"
SECRETS_FILE="$MONOREPO_ROOT/.config/secrets"

force=false
[[ "${1:-}" == "--force" ]] && force=true

# ── Vérifier le fichier secrets ──────────────────────────────
if [[ ! -f "$SECRETS_FILE" ]]; then
  echo "Fichier secrets introuvable : $SECRETS_FILE"
  echo "  Copier le template et remplir les valeurs :"
  echo "  cp $MONOREPO_ROOT/.config/secrets.example $SECRETS_FILE"
  exit 1
fi

# ── Fonction : créer .env et injecter secrets ────────────────
init_env() {
  local app_dir="$1"
  local app_name="$2"
  local env_file="$app_dir/.env"
  local example_file="$app_dir/.env.example"

  if [[ ! -f "$example_file" ]]; then
    echo "  [skip] $app_name : pas de .env.example"
    return
  fi

  if [[ -f "$env_file" && "$force" == false ]]; then
    echo "  [ok]   $app_name : .env existe deja (--force pour ecraser)"
  else
    cp "$example_file" "$env_file"
    echo "  [new]  $app_name : .env cree depuis .env.example"
  fi

  # Injecter les secrets dans le .env
  local injected=0
  while IFS='=' read -r key value; do
    # Ignorer commentaires et lignes vides
    [[ -z "$key" || "$key" =~ ^[[:space:]]*# ]] && continue
    key="$(echo "$key" | xargs)"
    value="$(echo "$value" | xargs)"
    [[ -z "$key" || -z "$value" ]] && continue

    if grep -q "^${key}=" "$env_file" 2>/dev/null; then
      sed -i '' "s|^${key}=.*|${key}=${value}|" "$env_file"
      injected=$((injected + 1))
    fi
  done < "$SECRETS_FILE"

  if [[ $injected -gt 0 ]]; then
    echo "  [keys] $app_name : $injected secret(s) injecte(s)"
  fi
}

# ── Initialiser les .env ─────────────────────────────────────
echo ""
echo "Initialisation des .env dans $PLATFORM_DIR"
echo "Secrets: $SECRETS_FILE"
echo ""

init_env "$PLATFORM_DIR/apps/api" "api"
init_env "$PLATFORM_DIR" "platform (docker-compose)"

echo ""
echo "Termine. Lancer: docker compose up -d"
