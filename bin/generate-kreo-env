#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLATFORM_DIR="$(dirname "$SCRIPT_DIR")"
OUTPUT_FILE="$PLATFORM_DIR/.env.kreo.generated"

random_hex() {
  openssl rand -hex 32
}

CLIENT_NAME="Kreo Docker"

creds="$(cd "$PLATFORM_DIR" && docker compose exec -T api php -r 'require "vendor/autoload.php"; $app = require "bootstrap/app.php"; $kernel = $app->make(Illuminate\Contracts\Console\Kernel::class); $kernel->bootstrap(); \Laravel\Passport\Client::query()->where("name", "Kreo Docker")->update(["revoked" => true]); $client = app(\Laravel\Passport\ClientRepository::class)->createClientCredentialsGrantClient("Kreo Docker"); echo $client->getKey()."|".$client->plainSecret;')"

IFS='|' read -r client_id client_secret <<< "$creds"

if [[ -z "${client_id:-}" || -z "${client_secret:-}" ]]; then
  echo "Impossible de generer les credentials OAuth de Kreo."
  exit 1
fi

cat > "$OUTPUT_FILE" <<EOF
# Generated by ./bin/generate-kreo-env
# Regenerated on each local setup to keep Kreo and platform-api aligned.
JWT_SECRET=$(random_hex)
JWT_REFRESH_SECRET=$(random_hex)
JWT_ACCESS_EXPIRATION=15m
PLATFORM_API_CLIENT_ID=$client_id
PLATFORM_API_CLIENT_SECRET=$client_secret
KREO_MACHINE_CLIENT_NAME=$CLIENT_NAME
EOF

chmod 600 "$OUTPUT_FILE"

echo "Generated $OUTPUT_FILE"
echo "  PLATFORM_API_CLIENT_ID=$client_id"
