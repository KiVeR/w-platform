# =============================================================================
# Docker Compose — Configuration
# =============================================================================
# Changer PORT_PREFIX pour un second worktree (ex: 81 → ports 8100, 8101, etc.)
COMPOSE_PROJECT_NAME=wellpack
PORT_PREFIX=80

# SDK path — chemin absolu vers wellpack/sdk (override si worktree hors arborescence)
# Par défaut ../../sdk résout depuis v2/platform/ vers la racine du monorepo
# SDK_PATH=/chemin/absolu/vers/sdk

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=wellpack
POSTGRES_PASSWORD=secret
POSTGRES_DB=platform-api

# =============================================================================
# API Laravel
# =============================================================================
APP_KEY=
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=debug

# Google OAuth (optionnel pour le dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Campagnes — drivers stub par défaut (pas d'appels réels Wepak/TriggerApi)
CAMPAIGN_SENDING_DRIVER=stub
CAMPAIGN_STATS_DRIVER=stub
WEPAK_API_URL=https://wepak.wellpack.fr
WEPAK_API_KEY=
TRIGGER_API_URL=http://localhost:8000
TRIGGER_API_KEY=

# =============================================================================
# Dashboard Nuxt
# =============================================================================
NUXT_PUBLIC_GOOGLE_CLIENT_ID=

# =============================================================================
# Convention de ports (PORT_PREFIX=80)
# =============================================================================
# API:        ${PORT_PREFIX}00 → 8000
# Dashboard:  ${PORT_PREFIX}01 → 8001
# PostgreSQL: ${PORT_PREFIX}32 → 8032
# Redis:      ${PORT_PREFIX}79 → 8079
# Mailpit UI: ${PORT_PREFIX}25 → 8025
# Horizon:    http://localhost:${PORT_PREFIX}00/horizon
# Scramble:   http://localhost:${PORT_PREFIX}00/docs/api
