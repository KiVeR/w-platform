# =============================================================================
# Docker Compose — Configuration
# =============================================================================
# Le nom du projet Docker est derive de PORT_PREFIX via docker-compose.yml
# pour isoler containers et volumes entre repo principal et worktrees.
# Si votre .env existant contient encore COMPOSE_PROJECT_NAME=wellpack,
# supprimez-le pour activer cette isolation par worktree.
# Ne definir COMPOSE_PROJECT_NAME que pour un override explicite.
# COMPOSE_PROJECT_NAME=wellpack-custom
# Changer PORT_PREFIX pour un second worktree (ex: 81 → ports 8100, 8101, etc.)
PORT_PREFIX=80

# SDK path — chemin absolu vers wellpack/sdk (override si worktree hors arborescence)
# Par défaut ../../sdk résout depuis v2/platform/ vers la racine du monorepo
# SDK_PATH=/chemin/absolu/vers/sdk

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=wellpack
POSTGRES_PASSWORD=secret
POSTGRES_DB=platform-api

# =============================================================================
# API Laravel (infrastructure only — docker hostnames/ports)
# =============================================================================
# App-specific vars (drivers, API keys, OAuth) belong in apps/api/.env
# and are read directly by Laravel via the mounted volume.
APP_ENV=local
APP_DEBUG=true

# =============================================================================
# Dashboard Nuxt
# =============================================================================
NUXT_PUBLIC_GOOGLE_CLIENT_ID=
NUXT_PUBLIC_PUSHER_ENABLED=false
NUXT_PUBLIC_PUSHER_APP_KEY=
NUXT_PUBLIC_PUSHER_CLUSTER=eu
NUXT_PUBLIC_PUSHER_HOST=
NUXT_PUBLIC_PUSHER_PORT=443
NUXT_PUBLIC_PUSHER_SCHEME=https
NUXT_PUBLIC_PUSHER_LOG_TO_CONSOLE=false

# =============================================================================
# Convention de ports (PORT_PREFIX=80)
# =============================================================================
# API:        ${PORT_PREFIX}00 → 8000
# Dashboard:  ${PORT_PREFIX}01 → 8001
# PostgreSQL: ${PORT_PREFIX}32 → 8032
# Redis:      ${PORT_PREFIX}79 → 8079
# Mailpit UI: ${PORT_PREFIX}25 → 8025
# Horizon:    http://localhost:${PORT_PREFIX}00/horizon
# Scramble:   http://localhost:${PORT_PREFIX}00/docs/api
