# Database
DATABASE_URL="postgresql://user:password@localhost:5432/database?schema=public"

# JWT Secrets (change in production!)
JWT_SECRET="your-jwt-secret-min-32-characters-long"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-characters"

# JWT Expiration
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# AI Services Configuration
# =========================

# Primary AI Provider (claude, openai, groq, mistral, together, ollama)
# Default: claude
AI_PROVIDER="claude"

# Optional: Override default model for the selected provider
# AI_MODEL="claude-sonnet-4-20250514"

# Anthropic (Claude)
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-api03-..."

# OpenAI
# Get your key at https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."

# Groq (fast inference)
# Get your key at https://console.groq.com/keys
# GROQ_API_KEY="gsk_..."

# Together AI
# Get your key at https://api.together.xyz/settings/api-keys
# TOGETHER_API_KEY="..."

# Mistral AI
# Get your key at https://console.mistral.ai/api-keys
# MISTRAL_API_KEY="..."

# Ollama (local)
# Set the host URL if running Ollama locally
# OLLAMA_HOST="http://localhost:11434"